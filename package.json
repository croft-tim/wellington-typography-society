{
  "name": "boilerplate-fullstack-routing",
  "type": "module",
  "version": "2.0.0",
  "main": "server/index.js",
  "license": "MIT",
  "keywords": [
    "fullstack",
    "routing"
  ],
  "scripts": {
    "test": "run-s test:client test:server",
    "test:client": "vitest run",
    "test:server": "vitest run --config vitest.server.config.ts",
    "start": "node dist/server.js",
    "dev": "run-p dev:client dev:server",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "run-s build:client build:server",
    "build:client": "vite build",
    "build:server": "esbuild --packages=external --platform=node --format=esm --outfile=dist/server.js --bundle server/index.ts",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx .",
    "knex": "knex --knexfile ./server/db/knexfile.js"
  },
  "eslintConfig": {
    "extends": "@devacademy/eslint-config/react",
    "ignorePatterns": [
      "bundle.js"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "knex": "^2.5.1",
    "sqlite3": "^5.1.7",
    "superagent": "^10.2.2"
  },
  "devDependencies": {
    "@devacademy/eslint-config": "^1.10.2",
    "@tanstack/eslint-plugin-query": "^5.12.2",
    "@tanstack/react-query": "^5.12.2",
    "@tanstack/react-query-devtools": "^5.13.3",
    "@testing-library/react": "^14.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/superagent": "^8.1.1",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^5.1.2",
    "esbuild": "^0.27.2",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^22.1.0",
    "npm-run-all": "^4.1.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^7.13.0",
    "sass": "^1.50.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^3.0.5"
  },
  "overrides": {
    "sqlite3": {
      "node-gyp": "12.2.0",
      "tar": "7.5.7"
    }
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "browserslist": "> 2%, not dead"
}
